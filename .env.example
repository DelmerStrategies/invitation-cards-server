# Copy this file to .env and fill in real values

# Set to "production" on the live server (hides internal error details).
NODE_ENV=development

# MongoDB connection string (local or Atlas). In production use a DB user with
# a password, e.g. mongodb+srv://user:pass@cluster/invitations
MONGODB_URI=mongodb://127.0.0.1:27017/invitations

# Port the server listens on
PORT=4000

# PDF rendering performance:
#   PDF_SCALE       3 = print quality (default), 2 = ~2x faster + smaller files
#   PDF_CONCURRENCY how many cards render in parallel (2–3 on a small VPS)
PDF_SCALE=3
PDF_CONCURRENCY=3

# Public base URL where guests reach the RSVP page (used to build QR links).
# Locally this can stay as below; in production set it to your real domain,
# e.g. https://rsvp.tomar-puk.com
PUBLIC_BASE_URL=http://localhost:4000

# Comma-separated origins allowed to call the API in development.
CORS_ORIGINS=http://localhost:5173

# --- Admin login (dashboard is locked to this single admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password
# Long random string used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
